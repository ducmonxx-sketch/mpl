# ===========================================================
# MPL API — environment variables (apps/api)
# Copy to `.env` and fill in real values. `.env` is gitignored.
# Loaded via dotenv (and prisma.config.ts reads DATABASE_URL).
# ===========================================================

# ── Core (required) ───────────────────────────────────────
# PostgreSQL connection string. Prisma 7 reads this from prisma.config.ts.
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/mpl_logistics"

# API server port
PORT=3001

# Frontend origin allowed by CORS (the Vite dev server)
CLIENT_URL="http://localhost:5173"

# JWT signing secret — generate a long random value, e.g.: openssl rand -hex 64
JWT_SECRET="CHANGE_ME_generate_a_long_random_secret"

# ── WhatsApp gateway: OpenWA (services/OpenWA) ────────────
# Self-hosted OpenWA REST gateway. If unset, sendWhatsApp() degrades to a
# no-op warning (no crash). See services/OpenWA.
OPENWA_BASE_URL="http://localhost:2785"
# OpenWA API key. For local dev with ALLOW_DEV_API_KEY=true it is "dev-admin-key";
# otherwise use the API_MASTER_KEY / generated key from OpenWA.
OPENWA_API_KEY="dev-admin-key"
# The id of the started/linked session in OpenWA (from the dashboard/API).
OPENWA_SESSION_ID=""

# ── Email delivery (optional; email.ts) ───────────────────
# If unset, email sends degrade to a no-op warning (no crash).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ── Admin alert recipients (optional; alertScheduler.ts) ──
# Where document-expiry alerts are sent. If unset, that alert path no-ops.
ADMIN_EMAIL=""
ADMIN_WHATSAPP=""
