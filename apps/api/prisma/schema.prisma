// prisma/schema.prisma
//
// Prisma 7 schema — notice two key differences from v6:
//   1. datasource db has NO url field — that moved to prisma.config.ts
//   2. generator uses "prisma-client" (not "prisma-client-js")
//      and outputs to a local folder, not node_modules
//
// Commands:
//   npx prisma migrate dev --name init   → create/update DB tables
//   npx prisma generate                  → regenerate TS client
//   npx prisma studio                    → visual DB browser
//   npx prisma db seed                   → run seed file
//   npx prisma migrate reset             → ⚠️ wipe DB (dev only)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma/"  // generated types go here, not node_modules
}

// In Prisma 7, the datasource block only declares the provider.
// The actual URL is in prisma.config.ts → datasource.url
datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Manufacturer {
  HONDA
  YAMAHA
  SUZUKI
}

enum AdminRole {
  SUPERADMIN
  OPERATIONS
  SUPPORT
  KEPALA_ARMADA
  PIC_PABRIK
  PIC_GUDANG
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DriverStatus {
  ACTIVE
  STANDBY      // reserved for a Standby shipment (pre-assigned, not yet on duty)
  ON_DUTY
  UNAVAILABLE
}

enum VehicleStatus {
  AVAILABLE
  STANDBY      // reserved for a Standby shipment (pre-assigned, not yet in use)
  IN_USE
  MAINTENANCE
}

enum ShipmentStatus {
  PENDING      // created by admin, not yet picked up by armada (Menunggu)
  STANDBY      // created/assigned by armada; awaiting driver-availability reconfirm before Ditugaskan
  DITUGASKAN   // driver & vehicle assigned + reconfirmed; staging before departure
  AT_PLANT     // Truck arrives at plant
  TRANSIT      // currently being delivered
  DITERIMA     // received at destination/gudang (Gudang leg) ← ADDED 2026-07-15
  DITURUNKAN   // unloaded at destination/gudang ← ADDED 2026-07-15
  DELIVERED    // successfully delivered (Selesai)
  FAILED       // delivery failed (legacy; no longer offered as a forward option)
  CANCELLED    // delivery cancelled after departure (vehicle returned with payload)
}

enum EventStatus {
  UPCOMING     // not yet reached this stop
  ACTIVE       // currently at this stop
  DONE         // already passed this stop
}

enum AuditActionType {
  VERIFY_USER
  REJECT_USER
  CREATE_DRIVER
  UPDATE_DRIVER
  DELETE_DRIVER
  CREATE_VEHICLE
  UPDATE_VEHICLE
  DELETE_VEHICLE
  CREATE_SHIPMENT
  UPDATE_SHIPMENT
  ASSIGN_DRIVER
  ASSIGN_VEHICLE
  UPDATE_STATUS
  ADD_SHIPMENT_EVENT
  CREATE_INVOICE
  SEND_INVOICE
  MARK_INVOICE_PAID
  CANCEL_INVOICE
  GENERATE_MAGIC_LINK
  RESET_PASSWORD
  SEND_WHATSAPP_DRIVER
  CREATE_USER
  UPDATE_USER
  DELETE_USER
  CREATE_ADMIN
}

// ============================================================
// ADMINS
// ============================================================

model Admin {
  id           String    @id @default(uuid())
  fullName     String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(OPERATIONS)
  avatarKey    String?   // storage key for profile picture (see lib/storage)
  createdAt    DateTime  @default(now())

  verifiedUsers     User[]          @relation("VerifiedByAdmin")
  managedDrivers    Driver[]        @relation("DriverManagedBy")
  managedVehicles   Vehicle[]       @relation("VehicleManagedBy")
  createdShipments  Shipment[]      @relation("ShipmentCreatedBy")
  updatedShipments  Shipment[]      @relation("ShipmentUpdatedBy")
  shipmentEvents    ShipmentEvent[] @relation("EventCreatedBy")
  sentNotifications Notification[]  @relation("NotificationSentBy")
  auditLogs         AdminAuditLog[]

  @@map("admins")
}

// ============================================================
// ADMIN AUDIT LOGS
// ============================================================

model AdminAuditLog {
  id             String          @id @default(uuid())
  actionType     AuditActionType
  targetTable    String
  targetRecordId String
  changesSummary String?
  timestamp      DateTime        @default(now())

  adminId String
  admin   Admin  @relation(fields: [adminId], references: [id])

  @@map("admin_audit_logs")
}

// ============================================================
// USERS (Clients)
// ============================================================

model User {
  id                 String             @id @default(uuid())
  fullName           String
  companyName        String?
  email              String             @unique
  passwordHash       String
  phoneNumber        String?
  city               String?
  address            String?
  npwp               String?
  avatarKey          String?            // storage key for profile picture (see lib/storage)
  verificationStatus VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  verifiedByAdminId String?
  verifiedByAdmin   Admin?  @relation("VerifiedByAdmin", fields: [verifiedByAdminId], references: [id])

  settings      UserSettings?
  shipments     Shipment[]
  notifications Notification[]

  @@map("users")
}

// ============================================================
// USER SETTINGS
// ============================================================

model UserSettings {
  id                    String  @id @default(uuid())
  emailNotifications    Boolean @default(true)
  whatsappNotifications Boolean @default(true)
  language              String  @default("id")
  theme                 String  @default("light")

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ============================================================
// DRIVERS
// ============================================================

model Driver {
  id            String       @id @default(uuid())
  fullName      String
  phoneNumber   String?
  status        DriverStatus @default(ACTIVE)
  licenseNumber String?      // nomor SIM
  licenseType   String?      // jenis SIM (A, B1, B2, dll.)
  licenseExpiry DateTime?    // masa berlaku SIM

  lastUpdatedByAdminId String?
  lastUpdatedByAdmin   Admin?  @relation("DriverManagedBy", fields: [lastUpdatedByAdminId], references: [id])

  shipments      Shipment[]
  primaryVehicle Vehicle?   @relation("VehiclePrimaryDriver")

  @@map("drivers")
}

// ============================================================
// VEHICLES
// ============================================================

model Vehicle {
  id           String        @id @default(uuid())
  type         String
  licensePlate String        @unique
  status       VehicleStatus @default(AVAILABLE)
  stnkExpiry   DateTime?     // masa berlaku STNK
  kirExpiry    DateTime?     // masa berlaku KIR
  serviceDate  DateTime?     // jadwal service berikutnya (di-flag sebagai compliance bila terlewat)
  chassisNumber String?      // nomor rangka
  engineNumber  String?      // nomor mesin
  brand         String?      // merk kendaraan (e.g. Toyota) — free text, picked from the VehicleBrand list
  modelName     String?      // nama/model kendaraan (e.g. Avanza). NOTE: 'modelName' not 'model' (Prisma keyword risk)
  color         String?      // warna kendaraan — free text, picked from the VehicleColor list

  primaryDriverId String? @unique  // 1:1 pairing — driver can only be primary on one vehicle
  primaryDriver   Driver? @relation("VehiclePrimaryDriver", fields: [primaryDriverId], references: [id])

  lastUpdatedByAdminId String?
  lastUpdatedByAdmin   Admin?  @relation("VehicleManagedBy", fields: [lastUpdatedByAdminId], references: [id])

  shipments Shipment[]

  @@map("vehicles")
}

// ============================================================
// VEHICLE LOOKUP TABLES (selectable brand/color lists)
// Lightweight lookups powering the Armada "pilih / tambah" dropdowns.
// The chosen name is copied onto Vehicle.brand / Vehicle.color as free text,
// so deleting a lookup row never orphans a vehicle.
// ============================================================

model VehicleBrand {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("vehicle_brands")
}

model VehicleColor {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("vehicle_colors")
}

// ============================================================
// PICKUP PLANTS
// ============================================================

model PickupPlant {
  id           String       @id @default(uuid())
  name         String       @unique
  code         String?
  manufacturer Manufacturer
  createdAt    DateTime     @default(now())

  shipments    Shipment[]

  @@map("pickup_plants")
}

// ============================================================
// SHIPMENTS
// ID format: #MPL-00001-JKT (generated in route code)
// ============================================================

model Shipment {
  id                     String         @id
  packageType            String
  weightKg               Decimal        @db.Decimal(10, 2)
  units                  Int?           // jumlah barang (pcs)
  serviceLevel           String
  originLocation         String
  destinationLocation    String
  specialNotes           String?
  status                 ShipmentStatus @default(PENDING)
  currentProgressPercent Int            @default(0)
  pickupDate             DateTime?
  completionDate         DateTime?
  createdAt              DateTime       @default(now())

  // --- New fields for pipeline roles ---
  shippingCategory       String?        // 'Unit', 'Cargo', 'Container'
  dimensions             String?        // for Cargo (PxLxT)
  containerType          String?        // for Container ('20 Feet', '40 Feet')
  pickupPlantId          String?
  pickupPlant            PickupPlant?   @relation(fields: [pickupPlantId], references: [id])
  vehicleCondition       String?        // by Pengurus Pabrik
  lkuNumber              String?        // by Pengurus Pabrik
  pabrikNotes            String?        // by Pengurus Pabrik
  serahTerimaUrl         String?        // by Kepala Gudang
  handoverNotes          String?        // by Kepala Gudang
  // -------------------------------------

  clientId String
  client   User   @relation(fields: [clientId], references: [id])

  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id])

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  createdByAdminId String?
  createdByAdmin   Admin?  @relation("ShipmentCreatedBy", fields: [createdByAdminId], references: [id])

  lastUpdatedByAdminId String?
  lastUpdatedByAdmin   Admin?  @relation("ShipmentUpdatedBy", fields: [lastUpdatedByAdminId], references: [id])

  events  ShipmentEvent[]

  @@map("shipments")
}

// ============================================================
// SHIPMENT EVENTS (Manual tracking timeline)
// ============================================================

model ShipmentEvent {
  id             String      @id @default(uuid())
  stepName       String
  location       String
  status         EventStatus @default(UPCOMING)
  driverNotes    String?
  eventTimestamp DateTime
  createdAt      DateTime    @default(now())

  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  createdByAdminId String?
  createdByAdmin   Admin?  @relation("EventCreatedBy", fields: [createdByAdminId], references: [id])

  @@map("shipment_events")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  sentByAdminId String?
  sentByAdmin   Admin?  @relation("NotificationSentBy", fields: [sentByAdminId], references: [id])

  @@map("notifications")
}

// ============================================================
// MAGIC LINKS
// ============================================================

model MagicLink {
  id          String   @id @default(uuid())
  token       String   @unique
  type        String   // 'registration' | 'reset_password'
  companyName String
  userId      String?
  used        Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  @@map("magic_links")
}

// ============================================================
// ADMIN NOTIFICATIONS
// ============================================================

model AdminNotification {
  id        String   @id @default(uuid())
  title     String
  message   String
  category  String
  isRead    Boolean  @default(false)
  linkTo    String?
  linkId    String?
  createdAt DateTime @default(now())
  @@map("admin_notifications")
}
