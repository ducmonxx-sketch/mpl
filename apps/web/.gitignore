# ===================================================
# apps/web — React + Vite Package .gitignore
# ===================================================

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules/

# Build outputs
dist/
dist-ssr/
build/

# Vite local overrides
*.local

# Environment variables — NEVER commit real secrets
.env
.env.*
!.env.example

# Test coverage
coverage/
.nyc_output/

# TypeScript cache
*.tsbuildinfo

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
