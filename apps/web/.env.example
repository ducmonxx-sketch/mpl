# ===================================================
# apps/web — React App Environment Variables
# ===================================================
# HOW TO USE:
#   cp apps/web/.env.example apps/web/.env
#   Fill in real values. NEVER commit the .env file.
#
# All variables MUST be prefixed with VITE_ to be
# accessible in the browser via import.meta.env.
# ===================================================

# --------------------------------------------------
# Cloudflare Turnstile (CAPTCHA / Bot Protection)
# --------------------------------------------------
# Obtain from: https://dash.cloudflare.com/ → Turnstile
# The "site key" is safe to expose publicly.
VITE_TURNSTILE_SITE_KEY=0x4AAAAAACpAqmuH8cPD6T9K

# --------------------------------------------------
# API Configuration
# --------------------------------------------------
# Base URL for backend API requests (no trailing slash).
# Example: https://api.mahkotaputralogistik.com
VITE_API_BASE_URL=https://api.mahkotaputralogistik.id

# --------------------------------------------------
# Contact Information
# --------------------------------------------------
# Primary contact email shown on the website.
VITE_CONTACT_EMAIL=mahkotaputralogistik@yahoo.com

# WhatsApp click-to-chat link (wa.link short URL or
# direct https://wa.me/<phone> URL).
VITE_WHATSAPP_LINK=https://wa.me/6281291166006

# --------------------------------------------------
# App Meta
# --------------------------------------------------
# Public-facing app name (used in page titles etc.)
VITE_APP_NAME=PT Mahkota Putra Logistik
