# ===================================================
# MPL Website 2 — Root Monorepo .gitignore
# ===================================================

# Dependencies
node_modules/

# Build outputs
dist/
dist-ssr/
build/
.cache/
.turbo/

# Environment variables
# NEVER commit real secrets. Only commit .env.example files.
.env
.env.*
!.env.example

# Vite local overrides
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test coverage
coverage/
.nyc_output/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.bak

# TypeScript cache
*.tsbuildinfo

# External services (run standalone / via Docker — not part of this repo)
# OpenWA WhatsApp gateway: cloned into services/, has its own git repo.
services/OpenWA/
